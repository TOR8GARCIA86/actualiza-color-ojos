{
  "name": "app-aoc",
  "version": "0.1.0",
  "description": "AOC — Cambia el color de los ojos (lentes de contacto virtuales) offline. Foto y video en vivo.",
  "main": "electron/main.js",
  "author": "AOC",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "fetch-model": "node scripts/fetch-model.js",
    "postinstall": "node scripts/fetch-model.js",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win"
  },
  "dependencies": {
    "@mediapipe/tasks-vision": "^0.10.14"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.aoc.eyecolor",
    "productName": "AOC Eye Color",
    "files": [
      "electron/**/*",
      "src/**/*",
      "assets/**/*",
      "node_modules/@mediapipe/tasks-vision/**/*"
    ],
    "mac": { "target": "dmg", "category": "public.app-category.photography" },
    "win": { "target": "nsis" }
  }
}
